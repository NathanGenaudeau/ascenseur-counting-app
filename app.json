{
  "expo": {
    "name": "ascenseur-counting-app",
    "slug": "ascenceur",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060b14"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
