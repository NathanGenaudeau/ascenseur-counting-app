      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.ascenseurcountingapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "c8c52824-e276-4848-aa7a-d9ca77b71bbf"
      }
    },
    "owner": "naklines-organization",
    "plugins": [
      "expo-font"
    ]
  }
}
