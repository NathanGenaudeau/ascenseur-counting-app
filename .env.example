# Copier vers `.env` pour le développement local (non versionné).
# Préfixe obligatoire Expo pour exposition au bundle : EXPO_PUBLIC_
# Ne pas y mettre de clés secrètes : tout ce qui est EXPO_PUBLIC_ est lisible dans l’app.

EXPO_PUBLIC_APP_ENV=development

# URL de base de l’API backend (HTTPS), si vous utilisez une couche REST au-dessus de Supabase.
EXPO_PUBLIC_API_URL=https://example.com/api

# Projet Supabase (publics — la clé anon reste soumise aux RLS sur les tables).
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
